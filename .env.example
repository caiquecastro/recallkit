DATABASE_URL="postgresql://postgres:postgres@localhost:5432/recallkit"

# Clerk authentication. Leave blank for Clerk keyless development, or set keys
# from https://dashboard.clerk.com.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/library"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/library"

# AI provider selection. Supported values: openai, openrouter.
AI_CHAT_PROVIDER="openai"
AI_EMBEDDING_PROVIDER="openai"

# OpenAI.
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_CHAT_MODEL="gpt-5.4-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# OpenRouter alternative.
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_CHAT_MODEL="openai/gpt-5.4-mini"
OPENROUTER_EMBEDDING_MODEL="openai/text-embedding-3-small"
OPENROUTER_SITE_URL=""
OPENROUTER_APP_NAME="RecallKit"
